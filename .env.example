# PieraCoin Environment Configuration
# Copy this file to .env and fill in your values
# Note: Never commit .env to git if it contains secrets

# ==========================================
# Backend Server (Go)
# ==========================================

# Port for the server (Render sets this automatically)
PORT=8080

# Admin secret key - MUST match ADMIN_KEY in client apps
# Change this to a strong random value in production
ADMIN_SECRET=your-super-secret-admin-key-12345

# ==========================================
# Admin Panel (Python)
# ==========================================

# Admin API key - MUST match ADMIN_SECRET on server
ADMIN_KEY=your-super-secret-admin-key-12345

# Server URL to connect to
SERVER_URL=http://localhost:8080

# ==========================================
# User Wallet (Python)
# ==========================================

# Server URL to connect to
SERVER_URL=http://localhost:8080

# ==========================================
# Production (Render.com)
# ==========================================

# On Render, set these in the Environment Variables section:
# ADMIN_SECRET=<generate-a-random-secure-key>
# PORT=<automatically set by Render>
