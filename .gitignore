# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# EXCEPT: Allow release/ executables
!release/*.exe

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work

# Environment files
.env
.env.local

# IDE files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Blockchain data (if using files)
*.db
blocks/
ledger/

# Python PyInstaller
*.spec
build/
dist/
*.pyc
__pycache__/
*.egg-info/

# Discord bot local files
/discord_bot/.env
/discord_bot/economy.json
